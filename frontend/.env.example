# API 베이스 URL (비우면 같은 오리진 + Vite 프록시로 /api 전달)
# VITE_API_URL=http://localhost:5000
# 백엔드가 다른 포트일 때 프록시 대상 (기본 http://localhost:5000)
# VITE_PROXY_TARGET=http://localhost:5000
#
# 소셜 로그인: 백엔드 .env 의 FRONTEND_PUBLIC_URL 이 이 프론트 주소와 같아야 합니다.
# 각 플랫폼 콘솔 리다이렉트 URI 예: http://localhost:5173/api/auth/oauth/google/callback
