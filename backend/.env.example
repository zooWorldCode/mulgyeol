PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=shop
MONGODB_TIMEOUT_MS=10000

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
# JWT_EXPIRES_IN=7d

# Production frontend URL, for CORS and final login redirects.
# Example: https://your-frontend.vercel.app
FRONTEND_PUBLIC_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Production backend URL, for OAuth callback URLs.
# On Render, set this to your Render service URL.
# Example: https://your-backend.onrender.com
BACKEND_PUBLIC_URL=http://localhost:5173
# Optional override. If set, this wins over BACKEND_PUBLIC_URL.
# OAUTH_REDIRECT_BASE_URL=https://your-backend.onrender.com

# Register these OAuth redirect URIs in each provider console:
# Google: {BACKEND_PUBLIC_URL}/api/auth/oauth/google/callback
# Kakao:  {BACKEND_PUBLIC_URL}/api/auth/oauth/kakao/callback
# Naver:  {BACKEND_PUBLIC_URL}/api/auth/oauth/naver/callback

# Google Cloud Console OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao Developers REST API key and optional client secret
KAKAO_REST_API_KEY=
# KAKAO_CLIENT_SECRET=

# Naver Developers Client ID / Client Secret
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
