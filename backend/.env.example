PORT=5000
# MongoDB Atlas → Connect → Drivers 에서 복사한 URI (비밀번호·클러스터 주소로 교체)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# JWT 서명용 비밀키 (충분히 긴 임의 문자열) — 로그인·소셜 state 에도 사용
JWT_SECRET=change-this-to-a-long-random-secret
# 선택: JWT 만료 (기본 7d)
# JWT_EXPIRES_IN=7d
# 프론트 개발 서버 주소 (필요 시 CORS 제한용)
# CORS_ORIGIN=http://localhost:5173

# --- OAuth (소셜 로그인) — 브라우저에 보이는 프론트 주소와 동일해야 합니다 (Vite 기본 5173)
# 리다이렉트 URI 로 각 플랫폼 콘솔에 아래 3개를 그대로 등록하세요:
#   {FRONTEND_PUBLIC_URL}/api/auth/oauth/google/callback
#   {FRONTEND_PUBLIC_URL}/api/auth/oauth/kakao/callback
#   {FRONTEND_PUBLIC_URL}/api/auth/oauth/naver/callback
FRONTEND_PUBLIC_URL=http://localhost:5173

# Google Cloud Console → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao Developers → 앱 키 → REST API 키 (= client_id). (보안) Client Secret 켠 경우만 입력
KAKAO_REST_API_KEY=
# KAKAO_CLIENT_SECRET=

# Naver Developers → Application → Client ID / Client Secret
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
